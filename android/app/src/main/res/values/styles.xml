<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════ Buttons ══════════ -->

    <!-- Base button parent (required for dot-notation children) -->
    <style name="ZillitButton" parent="android:Widget.Button">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ZillitButton.Primary">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/solidDarkText</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingLeft">@dimen/spacing_base</item>
        <item name="android:paddingRight">@dimen/spacing_base</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/input_height</item>
    </style>

    <style name="ZillitButton.Secondary">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingLeft">@dimen/spacing_md</item>
        <item name="android:paddingRight">@dimen/spacing_md</item>
        <item name="android:paddingTop">@dimen/spacing_sm</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ZillitButton.Danger">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/dangerText</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingLeft">@dimen/spacing_base</item>
        <item name="android:paddingRight">@dimen/spacing_base</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/input_height</item>
    </style>

    <style name="ZillitButton.Toolbar">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingLeft">@dimen/toolbar_btn_padding_h</item>
        <item name="android:paddingRight">@dimen/toolbar_btn_padding_h</item>
        <item name="android:paddingTop">@dimen/toolbar_btn_padding_v</item>
        <item name="android:paddingBottom">@dimen/toolbar_btn_padding_v</item>
        <item name="android:gravity">center</item>
        <item name="android:drawablePadding">@dimen/spacing_xs</item>
    </style>

    <!-- Small outlined toolbar button (mirrors iOS "Set as Default" / "Today") -->
    <style name="ZillitToolbarChip" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">28dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">@dimen/spacing_sm</item>
        <item name="android:paddingRight">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xxs</item>
        <item name="android:paddingBottom">@dimen/spacing_xxs</item>
        <item name="strokeColor">@color/borderButton</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">@dimen/radius_sm</item>
        <item name="rippleColor">@color/borderButton</item>
        <item name="iconSize">12dp</item>
        <item name="iconPadding">4dp</item>
        <item name="iconTint">@color/textSecondary</item>
    </style>

    <!-- ══════════ Input ══════════ -->
    <style name="ZillitInput">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textColorHint">@color/textPlaceholder</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:paddingLeft">@dimen/input_padding_h</item>
        <item name="android:paddingRight">@dimen/input_padding_h</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/input_height</item>
        <item name="android:singleLine">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:drawablePadding">@dimen/spacing_sm</item>
        <item name="android:drawableTint">@color/textSubtle</item>
    </style>

    <style name="ZillitInput.MultiLine">
        <item name="android:singleLine">false</item>
        <item name="android:minLines">3</item>
        <item name="android:gravity">top|start</item>
    </style>

    <!-- ══════════ Labels ══════════ -->
    <style name="ZillitLabel">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
    </style>

    <style name="ZillitLabel.Section">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/textMuted</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>

    <!-- ══════════ Title ══════════ -->
    <style name="ZillitTitle">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ZillitTitle.Hero">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <!-- ══════════ Card ══════════ -->
    <style name="ZillitCard">
        <item name="android:background">@drawable/bg_card_rounded</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <!-- iOS-like date/time pill — filled gray bg, rounded -->
    <style name="ZillitInputPill">
        <item name="android:background">@drawable/bg_input_pill</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">@dimen/spacing_md</item>
        <item name="android:paddingRight">@dimen/spacing_md</item>
        <item name="android:paddingTop">@dimen/spacing_sm</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <!-- iOS-like full-width dark Save button — bypasses Material3 orange tint -->
    <style name="ZillitSaveButton" parent="Widget.Material3.Button">
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/solidDarkText</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/solidDark</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/textMuted</item>
    </style>

    <!-- ══════════ Schedule Pill ══════════ -->
    <style name="ZillitPill">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/textBody</item>
        <item name="android:paddingLeft">@dimen/pill_padding_h</item>
        <item name="android:paddingRight">@dimen/pill_padding_h</item>
        <item name="android:paddingTop">@dimen/pill_padding_v</item>
        <item name="android:paddingBottom">@dimen/pill_padding_v</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:drawablePadding">@dimen/spacing_xs</item>
    </style>

    <!-- ══════════ Segmented Control ══════════ -->
    <style name="ZillitSegmented">
        <item name="android:background">@color/segmentedBg</item>
        <item name="android:padding">@dimen/spacing_xxs</item>
    </style>

    <!-- iOS-like segmented button (white pill on gray track, no Material3 purple tint) -->
    <style name="ZillitSegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">34dp</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/segmented_text_tint</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">34dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">@dimen/spacing_sm</item>
        <item name="android:paddingRight">@dimen/spacing_sm</item>
        <item name="backgroundTint">@color/segmented_bg_tint</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="rippleColor">@color/borderLight</item>
    </style>

    <!-- ══════════ Divider ══════════ -->
    <style name="ZillitDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/border</item>
    </style>

</resources>
