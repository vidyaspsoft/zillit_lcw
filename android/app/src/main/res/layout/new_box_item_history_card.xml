<?xml version="1.0" encoding="utf-8"?>
<!-- History card — iOS parity.
     MaterialCardView with rounded corners + subtle shadow.
     Colored left border strip + card content. -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_base"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/historyCardBg"
    app:strokeColor="@color/historyCardBorder"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Colored left border strip — clipped by the MaterialCardView's rounded corners -->
        <View
            android:id="@+id/borderStrip"
            android:layout_width="@dimen/history_border_width"
            android:layout_height="match_parent"
            android:background="@color/actionAdded" />

        <!-- Card content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/history_card_padding">

            <!-- Header row: action dot + ADDED label + target type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xs">

                <View
                    android:id="@+id/actionDot"
                    android:layout_width="@dimen/history_dot_size"
                    android:layout_height="@dimen/history_dot_size"
                    android:background="@drawable/bg_today_circle"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvActionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvTargetType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/textMuted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- Title in serif quotes — iOS parity: bold Georgia-style -->
            <TextView
                android:id="@+id/tvHistoryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textColor="@color/textPrimary"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <!-- Details line -->
            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/textSubtle"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <!-- Divider before footer -->
            <View
                style="@style/ZillitDivider"
                android:background="@color/historyCardBorder"
                android:layout_marginVertical="@dimen/spacing_xs" />

            <!-- Footer: date+time  |  by Name  |  REV pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDateTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/textFaint" />

                <TextView
                    android:id="@+id/tvByName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/textFaint"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvRevPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/textMuted"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_secondary"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="@dimen/spacing_xxs" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
