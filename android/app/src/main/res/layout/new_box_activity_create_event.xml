<?xml version="1.0" encoding="utf-8"?>
<!-- Create Event/Note — iOS parity (CreateEventView.swift):
     back chevron + centered title, reordered form, full-width dark Save button. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pageBg">

    <!-- Header bar: back chevron + centered title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingHorizontal="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:contentDescription="@string/action_cancel"
            app:tint="@color/textPrimary" />

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ce_add_event"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <View style="@style/ZillitDivider" />

    <!-- Event / Note tab switcher — hidden when tab extra is passed -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/eventNoteToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_segmented_track"
            android:padding="2dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEventTab"
                style="@style/ZillitSegmentedButton"
                android:layout_width="wrap_content"
                android:paddingLeft="@dimen/spacing_lg"
                android:paddingRight="@dimen/spacing_lg"
                android:text="@string/ce_event_tab" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNoteTab"
                style="@style/ZillitSegmentedButton"
                android:layout_width="wrap_content"
                android:paddingLeft="@dimen/spacing_lg"
                android:paddingRight="@dimen/spacing_lg"
                android:text="@string/ce_note_tab" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- LINK TO A SCHEDULE DAY (optional) — web parity, shown on both Event and Note -->
            <LinearLayout
                android:id="@+id/linkDayCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_link_schedule_day" />

                <Spinner
                    android:id="@+id/spinnerLinkDay"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ═══ EVENT FORM ═══ -->
            <LinearLayout
                android:id="@+id/eventForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ADD TITLE * -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_title_hint" />

                <EditText
                    android:id="@+id/etEventTitle"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ce_title_hint"
                    android:inputType="text"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- EVENT DESCRIPTION -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_description_hint" />

                <EditText
                    android:id="@+id/etEventDesc"
                    style="@style/ZillitInput.MultiLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint=""
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:layout_marginBottom="@dimen/spacing_lg" />

                <!-- Full Day inline row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ce_full_day"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchFullDay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Start Date | End Date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="@dimen/spacing_sm">

                        <TextView
                            style="@style/ZillitLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cs_start_date" />

                        <TextView
                            android:id="@+id/tvEventStartDate"
                            style="@style/ZillitInputPill"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            style="@style/ZillitLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cs_end_date" />

                        <TextView
                            android:id="@+id/tvEventEndDate"
                            style="@style/ZillitInputPill"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Start Time | End Time row (hidden when full day) -->
                <LinearLayout
                    android:id="@+id/timeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="@dimen/spacing_sm">

                        <TextView
                            style="@style/ZillitLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ce_start_time" />

                        <TextView
                            android:id="@+id/tvStartTime"
                            style="@style/ZillitInputPill"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_sm">

                        <TextView
                            style="@style/ZillitLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ce_end_time" />

                        <TextView
                            android:id="@+id/tvEndTime"
                            style="@style/ZillitInputPill"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <!-- REPEAT -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_repeat" />

                <Spinner
                    android:id="@+id/spinnerRepeat"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- Repeat end date (hidden unless repeat != none) -->
                <LinearLayout
                    android:id="@+id/repeatEndDateContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        style="@style/ZillitLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ce_repeat_end_date" />

                    <TextView
                        android:id="@+id/tvRepeatEndDate"
                        style="@style/ZillitInputPill"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/ce_repeat_end_date_hint"
                        android:textColorHint="@color/textPlaceholder" />
                </LinearLayout>

                <!-- SELECT TIMEZONE -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_timezone" />

                <Spinner
                    android:id="@+id/spinnerTimezone"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- ADD REMINDER/ALERT -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_reminder" />

                <Spinner
                    android:id="@+id/spinnerReminder"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- CALL TYPE -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_call_type" />

                <Spinner
                    android:id="@+id/spinnerCallType"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- LOCATION -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_location" />

                <EditText
                    android:id="@+id/etLocation"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ce_location_hint"
                    android:inputType="text"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- DISTRIBUTE TO (web parity: functional dropdown) -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_distribute_to" />

                <Spinner
                    android:id="@+id/spinnerDistributeTo"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_distribute_hint"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/textSubtle"
                    android:textStyle="italic"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- ORGANIZER EXCLUDED (web parity: boxed checkbox) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <CheckBox
                        android:id="@+id/cbOrganizerExcluded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ce_organizer_excluded"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/textBody"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="@dimen/spacing_xs" />
                </LinearLayout>

                <!-- EVENT COLOR (web parity: 6 presets) -->
                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_color" />

                <LinearLayout
                    android:id="@+id/eventColorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- Hidden: text color picker (kept for API compat, not shown on iOS) -->
                <LinearLayout
                    android:id="@+id/textColorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ═══ NOTE FORM (web parity: Title, Notes, Color) ═══ -->
            <LinearLayout
                android:id="@+id/noteForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_note_title_label" />

                <EditText
                    android:id="@+id/etNoteTitle"
                    style="@style/ZillitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ce_note_title_hint"
                    android:inputType="text"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_note_text_label" />

                <EditText
                    android:id="@+id/etNoteText"
                    style="@style/ZillitInput.MultiLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ce_note_text_hint"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    style="@style/ZillitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ce_bg_color" />

                <LinearLayout
                    android:id="@+id/noteColorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ═══ FOOTER: single full-width dark Save button (iOS parity) ═══ -->
    <View style="@style/ZillitDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/ZillitSaveButton"
            android:layout_width="match_parent"
            android:text="@string/ce_save_event" />
    </LinearLayout>
</LinearLayout>
