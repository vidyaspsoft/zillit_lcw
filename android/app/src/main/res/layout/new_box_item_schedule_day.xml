<?xml version="1.0" encoding="utf-8"?>
<!-- Schedule day row — two modes:
     1. By Date (scheduleBlockLayout hidden): date + pill + title in one row.
     2. By Schedule (byDateLayout hidden): iOS-parity card — color square + typeName
        + day count on top, date range below.
     Either layout is toggled visibility in ScheduleViewHolder.bind(). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- ══════════ BY DATE LAYOUT (existing) ══════════ -->
    <LinearLayout
        android:id="@+id/byDateLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_base"
        android:paddingVertical="@dimen/spacing_md"
        android:background="?attr/selectableItemBackground">

        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="@dimen/text_md"
            android:textColor="@color/textPrimary"
            android:fontFamily="serif" />

        <LinearLayout
            android:id="@+id/typePill"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/dotColor"
                android:layout_width="@dimen/pill_dot_size"
                android:layout_height="@dimen/pill_dot_size"
                android:background="@drawable/bg_schedule_pill"
                android:layout_marginEnd="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/tvTypeName"
                style="@style/ZillitPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:textSize="@dimen/text_md"
            android:textColor="@color/textBody"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tvTodayBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bs_today"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/successText"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:visibility="gone"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xxs"
            android:layout_marginStart="@dimen/spacing_sm" />

        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:contentDescription="Expand" />
    </LinearLayout>

    <!-- ══════════ BY SCHEDULE LAYOUT (iOS parity) ══════════ -->
    <LinearLayout
        android:id="@+id/byScheduleLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_base"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground">

        <!-- Top row: color square + typeName (+ optional title) + day count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbSelectBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <!-- Larger color square (matches iOS 12x12) -->
            <View
                android:id="@+id/colorSquare"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_schedule_pill" />

            <TextView
                android:id="@+id/tvBlockTypeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/tvBlockTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/textSecondary"
                android:fontFamily="serif"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginStart="@dimen/spacing_xs"
                android:visibility="gone" />

            <Space
                android:id="@+id/blockSpacer"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvDayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/textMuted"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Date range (iOS style: smaller gray text below) -->
        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/textSubtle"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

    <!-- Shared tap targets over both layouts — handled via rowContainer in code. -->
    <!-- NB: ScheduleViewHolder still references @+id/rowContainer; we use the active layout. -->
    <View
        android:id="@+id/rowContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Edit + Delete chips -->
    <LinearLayout
        android:id="@+id/rowActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_base"
        android:paddingBottom="@dimen/spacing_sm">

        <TextView
            android:id="@+id/btnRowEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_edit"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/textLink"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_chip_link"
            android:drawableStart="@drawable/ic_edit"
            android:drawablePadding="@dimen/spacing_xxs"
            app:drawableTint="@color/textLink" />

        <TextView
            android:id="@+id/btnRowDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/dangerBg"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_chip_danger"
            android:drawableStart="@drawable/ic_trash"
            android:drawablePadding="@dimen/spacing_xxs"
            android:layout_marginStart="@dimen/spacing_sm"
            app:drawableTint="@color/dangerBg" />
    </LinearLayout>

    <View
        style="@style/ZillitDivider"
        android:background="@color/borderLight" />
</LinearLayout>
