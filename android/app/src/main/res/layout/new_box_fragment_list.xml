<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pageBg"
    android:padding="@dimen/spacing_sm">

    <!-- List toolbar: 2 rows for responsiveness (mirrors calendar page) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="@dimen/spacing_sm"
        android:paddingHorizontal="@dimen/spacing_sm">

        <!-- Row 1: Mode toggle + Set Default -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/listModeToggle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnByDate"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="@string/bs_by_date"
                    android:textSize="@dimen/text_sm"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBySchedule"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="@string/bs_by_schedule"
                    android:textSize="@dimen/text_sm"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListSetDefault"
                style="@style/ZillitToolbarChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bs_set_default"
                app:icon="@drawable/ic_grid_2x2"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

        <!-- Row 2: Search (grows) + Filter button (opens bottom-sheet) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm">

            <EditText
                android:id="@+id/etListSearch"
                style="@style/ZillitInput"
                android:layout_width="0dp"
                android:layout_height="@dimen/input_height"
                android:layout_weight="1"
                android:hint="@string/bs_search_hint"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenFilters"
                style="@style/ZillitToolbarChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bs_filter"
                app:icon="@drawable/ic_filter"
                android:layout_marginStart="@dimen/spacing_sm" />

            <!-- Active-filter count badge — visible when >=1 filter is applied. -->
            <TextView
                android:id="@+id/tvFilterBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="20dp"
                android:minHeight="20dp"
                android:gravity="center"
                android:textColor="@color/surface"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_accent"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:layout_marginStart="@dimen/spacing_xs"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Row 3: Select + Delete Selected -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm">

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelect"
                style="@style/ZillitToolbarChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bs_select" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSelected"
                style="@style/ZillitToolbarChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bs_delete_selected"
                android:textColor="@color/dangerBg"
                app:strokeColor="@color/dangerBg"
                android:visibility="gone"
                android:layout_marginStart="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>

    <!-- Schedule list RecyclerView -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="1dp"
        android:layout_marginTop="@dimen/spacing_xs">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/scheduleList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:text="📋" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_schedule_title"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/textSubtle"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_schedule_desc"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/textDisabled"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
