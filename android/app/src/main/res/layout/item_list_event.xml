<?xml version="1.0" encoding="utf-8"?>
<!-- Event/Note row for List view — colored left strip + title + date + details. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/surface">

    <!-- Coloured vertical strip (matches event color) -->
    <View
        android:id="@+id/leColorStrip"
        android:layout_width="3dp"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <!-- Kind badge: EVENT / NOTE -->
        <TextView
            android:id="@+id/leKindBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textColor="@color/textSubtle" />

        <TextView
            android:id="@+id/leTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/leDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/textMuted"
            android:layout_marginTop="@dimen/spacing_xxs" />

        <TextView
            android:id="@+id/leDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/textSubtle"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:visibility="gone" />

        <!-- Edit + Delete action chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_sm">

            <TextView
                android:id="@+id/leBtnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_edit"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/textLink"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@drawable/bg_chip_link"
                android:drawableStart="@drawable/ic_edit"
                android:drawablePadding="@dimen/spacing_xxs"
                app:drawableTint="@color/textLink" />

            <TextView
                android:id="@+id/leBtnDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_delete"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/dangerBg"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@drawable/bg_chip_danger"
                android:drawableStart="@drawable/ic_trash"
                android:drawablePadding="@dimen/spacing_xxs"
                android:layout_marginStart="@dimen/spacing_sm"
                app:drawableTint="@color/dangerBg" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
</LinearLayout>
